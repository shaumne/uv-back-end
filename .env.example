# ── BlancMate API — Environment Variables Template ───────────────────────────
#
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
#
# Never commit .env to version control. It is already listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────

# Set to false in production.
DEBUG=false

# Application log level: debug | info | warning | error | critical
LOG_LEVEL=info

# ── Security ──────────────────────────────────────────────────────────────────

# X-API-Key header value required on all non-exempt API endpoints.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable authentication (local development only).
API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins.
# Use "*" for development, specific domains in production.
# Example: ALLOWED_ORIGINS=https://app.uvdosimetry.com,https://staging.uvdosimetry.com
ALLOWED_ORIGINS=*

# ── Image Validation ──────────────────────────────────────────────────────────

# Maximum allowed image size in bytes (default: 10 MB = 10485760)
MAX_IMAGE_SIZE_BYTES=10485760

# Minimum image dimension in pixels (width and height must exceed this)
MIN_IMAGE_DIMENSION_PX=200

# ── Gunicorn (production only) ────────────────────────────────────────────────

# Number of worker processes. Leave unset to auto-detect (2 × CPUs + 1).
# GUNICORN_WORKERS=5

# Bind address for the Gunicorn server.
GUNICORN_BIND=0.0.0.0:8000

# Trusted reverse proxy IP addresses (for X-Forwarded-For header).
# Set to the nginx / Cloud Run proxy IP in production.
FORWARDED_ALLOW_IPS=127.0.0.1
